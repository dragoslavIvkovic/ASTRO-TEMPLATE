---
import { Icon } from 'astro-icon/components';
---

<dialog id="newsletter-modal" class="p-0 rounded-2xl shadow-2xl backdrop:backdrop-blur-sm bg-transparent border-none outline-none overflow-visible">
  <div class="relative bg-white dark:bg-slate-900 w-[95vw] max-w-md p-8 rounded-2xl border border-gray-100 dark:border-slate-800">
    <button id="close-modal" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors" aria-label="Close">
      <Icon name="tabler:x" class="w-6 h-6" />
    </button>

    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Join Our Newsletter</h2>
      <p class="text-gray-600 dark:text-slate-400">Stay updated with our latest news and offers.</p>
    </div>

    <form id="newsletter-form" class="space-y-4">
      <div>
        <label for="news-email" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">Email Address</label>
        <input 
          type="email" 
          id="news-email" 
          name="email" 
          required 
          placeholder="you@example.com"
          class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all"
        />
        <span class="error-msg hidden text-xs text-red-500 mt-1">Please enter a valid email.</span>
      </div>



      <div>
        <label for="interests" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">What are you interested in?</label>
        <textarea 
          id="interests" 
          name="interests" 
          rows="3" 
          required
          placeholder="Tell us a bit about what you'd like to hear from us..."
          class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all resize-none"
        ></textarea>
        <span class="error-msg hidden text-xs text-red-500 mt-1">This field is required.</span>
      </div>

      <button 
        type="submit" 
        id="submit-btn" 
        disabled
        class="w-full py-4 px-6 rounded-lg bg-primary text-white font-bold text-lg shadow-lg hover:shadow-xl hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed transition-all flex items-center justify-center gap-2"
      >
        <span id="btn-text">Subscribe Now</span>
        <Icon id="btn-loader" name="tabler:loader-2" class="w-5 h-5 animate-spin hidden" />
      </button>

      <p id="form-message" class="text-center text-sm font-medium hidden"></p>
    </form>
  </div>
</dialog>

<style>
  dialog {
    animation: fade-out 0.3s ease-out;
  }
  dialog[open] {
    animation: fade-in 0.3s ease-out;
  }
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease-out;
  }
  dialog[open]::backdrop {
    opacity: 1;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes fade-out {
    from { opacity: 1; transform: scale(1) translateY(0); }
    to { opacity: 0; transform: scale(0.9) translateY(20px); }
  }
</style>

<script>
  const modal = document.getElementById('newsletter-modal') as HTMLDialogElement;
  const closeBtn = document.getElementById('close-modal');
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnLoader = document.getElementById('btn-loader');
  const formMessage = document.getElementById('form-message');

  const inputs = {
    email: document.getElementById('news-email') as HTMLInputElement,
    interests: document.getElementById('interests') as HTMLTextAreaElement
  };

  const validate = () => {
    const emailValid = inputs.email.value && /^\S+@\S+\.\S+$/.test(inputs.email.value);
    const interestsValid = inputs.interests.value.length > 5;

    // Email validation visual feedback
    if (inputs.email.value && !emailValid) {
      inputs.email.nextElementSibling?.classList.remove('hidden');
    } else {
      inputs.email.nextElementSibling?.classList.add('hidden');
    }

    submitBtn.disabled = !(emailValid && interestsValid);
  };

  Object.values(inputs).forEach(input => {
    input.addEventListener('input', validate);
  });

  closeBtn?.addEventListener('click', () => modal.close());
  
  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.close();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // UI Loading state
    submitBtn.disabled = true;
    btnText!.textContent = 'Sending...';
    btnLoader!.classList.remove('hidden');
    formMessage!.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const response = await fetch('/api/newsletter', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      if (response.ok) {
        formMessage!.textContent = 'Thank you for subscribing! Check your email soon.';
        formMessage!.className = 'text-center text-sm font-medium text-green-600 dark:text-green-400 mt-4';
        formMessage!.classList.remove('hidden');
        form.reset();
        setTimeout(() => modal.close(), 3000);
      } else {
        throw new Error(result.message || 'Something went wrong');
      }
    } catch (err: any) {
      formMessage!.textContent = `Error: ${err.message}`;
      formMessage!.className = 'text-center text-sm font-medium text-red-600 dark:text-red-400 mt-4';
      formMessage!.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText!.textContent = 'Subscribe Now';
      btnLoader!.classList.add('hidden');
    }
  });

  // Export open function to window
  (window as any).openNewsletterModal = () => {
    modal.showModal();
  };
</script>
