---
import { Icon } from 'astro-icon/components';
import { SITE_DATA } from '~/site-config';
---

<!-- 
  Floating contact icons for mobile devices.
  Hidden on desktop (md:hidden).
  Fixed on the right side of the screen.
-->
<div class="fixed right-0 top-1/2 -translate-y-1/2 z-50 flex flex-col gap-2 p-2 md:hidden">
  {SITE_DATA?.client?.phone && (
    <a 
      href={`tel:${SITE_DATA.client.phone.replace(/[^0-9+]/g, '')}`} 
      class="group relative flex h-12 w-12 items-center justify-center rounded-l-xl bg-blue-600 text-white shadow-lg transition-transform hover:-translate-x-1" 
      aria-label="Call Us"
    >
      <Icon name="tabler:phone" class="h-6 w-6 animate-pulse" />
      <span class="absolute inset-0 rounded-l-xl bg-blue-400 opacity-20 animate-ping pointer-events-none"></span>
    </a>
  )}
  {SITE_DATA?.client?.email && (
    <button 
      onclick="window.openNewsletterModal()" 
      class="flex h-12 w-12 items-center justify-center rounded-l-xl bg-gray-800 text-white shadow-lg transition-transform hover:-translate-x-1 dark:bg-gray-700 cursor-pointer" 
      aria-label="Email Us"
    >
      <Icon name="tabler:mail" class="h-6 w-6" />
    </button>
  )}
</div>
