---
import { Icon } from 'astro-icon/components';
---

<button
  id="scroll-to-top"
  aria-label="Scroll to top"
  class="group fixed bottom-6 right-6 z-50 flex h-12 w-12 translate-y-20 items-center justify-center rounded-full bg-white text-gray-700 opacity-0 shadow-xl transition-all duration-300 hover:bg-gray-50 hover:text-primary hover:shadow-2xl focus:outline-none dark:bg-slate-800 dark:text-gray-300 dark:hover:bg-slate-700"
>
  <!-- Background circle (empty) -->
  <svg class="absolute inset-0 h-full w-full -rotate-90" viewBox="0 0 48 48">
    <circle
      cx="24"
      cy="24"
      r="22"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      class="text-gray-200 dark:text-slate-600"
    ></circle>
    <!-- Progress circle (filled via JS) -->
    <circle
      id="scroll-progress-circle"
      cx="24"
      cy="24"
      r="22"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-dasharray="138.23"
      stroke-dashoffset="138.23"
      class="text-primary transition-all duration-150 ease-out"
    ></circle>
  </svg>
  
  <Icon name="tabler:arrow-up" class="h-6 w-6 relative z-10 transition-transform group-hover:-translate-y-1" />
</button>

<script>
  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    const scrollToTopBtn = document.getElementById('scroll-to-top');
    const progressCircle = document.getElementById('scroll-progress-circle');
    
    if (!scrollToTopBtn || !progressCircle) return;

    // Circle radius is 22, circumference is 2 * PI * 22 = 138.23
    const circumference = 138.23;

    const updateScrollProgress = () => {
      const scrollY = window.scrollY;
      const windowHeight = window.innerHeight;
      const documentHeight = document.documentElement.scrollHeight;
      
      // Calculate how far down the user has scrolled
      const maxScroll = documentHeight - windowHeight;
      let scrollPercentage = maxScroll > 0 ? scrollY / maxScroll : 0;
      
      // Ensure percentage is between 0 and 1
      scrollPercentage = Math.min(Math.max(scrollPercentage, 0), 1);

      // Update the circle's stroke-dashoffset
      // When scrollPercentage is 0, offset is full circumference (empty)
      // When scrollPercentage is 1, offset is 0 (full)
      const offset = circumference - (scrollPercentage * circumference);
      progressCircle.style.strokeDashoffset = `${offset}`;

      // Show or hide the button
      if (scrollY > 300) {
        scrollToTopBtn.classList.remove('opacity-0', 'translate-y-20', 'pointer-events-none');
        scrollToTopBtn.classList.add('opacity-100', 'translate-y-0');
      } else {
        scrollToTopBtn.classList.remove('opacity-100', 'translate-y-0');
        scrollToTopBtn.classList.add('opacity-0', 'translate-y-20', 'pointer-events-none');
      }
    };

    // Scroll to top when clicked
    scrollToTopBtn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });

    // Update on scroll and initial load
    window.addEventListener('scroll', updateScrollProgress, { passive: true });
    window.addEventListener('resize', updateScrollProgress, { passive: true });
    updateScrollProgress();
  });
</script>
